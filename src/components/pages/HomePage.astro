---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import portraitKay from "../../assets/kayhochkant.jpg";
import { useTranslations, localizedPath } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";
import { getCollection } from "astro:content";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const allPosts = (
  await getCollection(
    "blog",
    ({ data }) => !data.draft && (data.lang ?? "de") === lang,
  )
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pillarPosts = allPosts
  .filter((p) => p.data.tags?.includes("pillar"))
  .slice(0, 3);
const pillarIds = new Set(pillarPosts.map((p) => p.id));
const latestPosts = allPosts.filter((p) => !pillarIds.has(p.id)).slice(0, 3);

const dateLocale = lang === "de" ? "de-DE" : "en-US";
---

<Layout lang={lang}>
  <!-- Hero -->
  <section
    class="grid items-center gap-12 py-20 sm:py-24 md:grid-cols-[1.3fr_1fr]"
  >
    <div>
      <p class="eyebrow">{t.home.eyebrow}</p>
      <h1 class="mt-6 text-5xl leading-[1.05] sm:text-6xl md:text-7xl">
        {t.home.headlinePre}{" "}
        <span class="italic text-[var(--color-accent)]"
          >{t.home.headlineAccent}</span
        >{t.home.headlinePost}
      </h1>
      <p
        class="mt-8 max-w-xl text-lg leading-relaxed text-[var(--color-fg-soft)] sm:text-xl"
      >
        {t.home.lead}
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href={localizedPath(lang, "/consulting")} class="btn-primary">
          {t.home.ctaPrimary}
          <span aria-hidden="true">→</span>
        </a>
        <a href={localizedPath(lang, "/about")} class="btn-secondary">
          {t.home.ctaSecondary}
        </a>
      </div>
    </div>
    <Image
      src={portraitKay}
      alt={t.about.portraitLabel}
      widths={[400, 600, 900]}
      sizes="(min-width: 768px) 400px, 100vw"
      format="webp"
      class="rounded-xl"
    />
  </section>

  <!-- Credibility strip -->
  <section class="border-y border-[var(--color-border)] py-8">
    <p
      class="text-center text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-muted)]"
    >
      {t.home.credibility}
    </p>
    <div
      class="mt-4 flex flex-wrap items-center justify-center gap-x-10 gap-y-3 font-serif text-lg text-[var(--color-fg-soft)]"
      style="font-family: var(--font-serif);"
    >
      <span class="flex items-center gap-2">
        <svg
          class="h-5 w-5 text-[var(--color-muted)]"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          ><title>Amazon</title><path
            d="M.045 18.02c.072-.116.187-.124.348-.022 3.636 2.11 7.594 3.166 11.87 3.166 2.852 0 5.668-.533 8.447-1.595l.315-.14c.138-.06.234-.1.293-.13.226-.088.39-.046.525.13.12.174.09.336-.12.48-.256.19-.6.41-1.006.654-1.244.743-2.64 1.316-4.185 1.726a17.617 17.617 0 01-10.951-.577 17.88 17.88 0 01-5.43-3.35c-.1-.074-.151-.15-.151-.22 0-.047.021-.09.051-.13zm6.565-6.218c0-1.005.247-1.863.743-2.577.495-.71 1.17-1.25 2.04-1.615.796-.335 1.756-.575 2.912-.72.39-.046 1.033-.103 1.92-.174v-.37c0-.93-.105-1.558-.3-1.875-.302-.43-.78-.65-1.44-.65h-.182c-.48.046-.896.196-1.246.46-.35.27-.575.63-.675 1.096-.06.3-.206.465-.435.51l-2.52-.315c-.248-.06-.372-.18-.372-.39 0-.046.007-.09.022-.15.247-1.29.855-2.25 1.82-2.88.976-.616 2.1-.975 3.39-1.05h.54c1.65 0 2.957.434 3.888 1.29.135.15.27.3.405.48.12.165.224.314.283.45.075.134.15.33.195.57.06.254.105.42.135.51.03.104.062.3.076.615.01.313.02.493.02.553v5.28c0 .376.06.72.165 1.036.105.313.21.54.315.674l.51.674c.09.136.136.256.136.36 0 .12-.06.226-.18.314-1.2 1.05-1.86 1.62-1.963 1.71-.165.135-.375.15-.63.045a6.062 6.062 0 01-.526-.496l-.31-.347a9.391 9.391 0 01-.317-.42l-.3-.435c-.81.886-1.603 1.44-2.4 1.665-.494.15-1.093.227-1.83.227-1.11 0-2.04-.343-2.76-1.034-.72-.69-1.08-1.665-1.08-2.94l-.05-.076zm3.753-.438c0 .566.14 1.02.425 1.364.285.34.675.512 1.155.512.045 0 .106-.007.195-.02.09-.016.134-.023.166-.023.614-.16 1.08-.553 1.424-1.178.165-.28.285-.58.36-.91.09-.32.12-.59.135-.8.015-.195.015-.54.015-1.005v-.54c-.84 0-1.484.06-1.92.18-1.275.36-1.92 1.17-1.92 2.43l-.035-.02zm9.162 7.027c.03-.06.075-.11.132-.17.362-.243.714-.41 1.05-.5a8.094 8.094 0 011.612-.24c.14-.012.28 0 .41.03.65.06 1.05.168 1.172.33.063.09.099.228.099.39v.15c0 .51-.149 1.11-.424 1.8-.278.69-.664 1.248-1.156 1.68-.073.06-.14.09-.197.09-.03 0-.06 0-.09-.012-.09-.044-.107-.12-.064-.24.54-1.26.806-2.143.806-2.64 0-.15-.03-.27-.087-.344-.145-.166-.55-.257-1.224-.257-.243 0-.533.016-.87.046-.363.045-.7.09-1 .135-.09 0-.148-.014-.18-.044-.03-.03-.036-.047-.02-.077 0-.017.006-.03.02-.063v-.06z"
          ></path></svg
        >
        <span>Amazon</span>
      </span>
      <span class="text-[var(--color-border-strong)]">·</span>
      <span class="flex items-center gap-2">
        <svg
          class="h-5 w-5 text-[var(--color-muted)]"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          ><title>Bosch</title><path
            d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12C23.996 5.374 18.626.004 12 0zm0 22.88C5.991 22.88 1.12 18.009 1.12 12S5.991 1.12 12 1.12 22.88 5.991 22.88 12c-.006 6.006-4.874 10.874-10.88 10.88zm4.954-18.374h-.821v4.108h-8.24V4.506h-.847a8.978 8.978 0 0 0 0 14.988h.846v-4.108h8.24v4.108h.822a8.978 8.978 0 0 0 0-14.988zM6.747 17.876a7.86 7.86 0 0 1 0-11.752v11.752zm9.386-3.635h-8.24V9.734h8.24v4.507zm1.12 3.61V6.124a7.882 7.882 0 0 1 0 11.727z"
          ></path></svg
        >
        <span>Bosch Center for AI</span>
      </span>
      <span class="text-[var(--color-border-strong)]">·</span>
      <span class="flex items-center gap-2">
        <svg
          class="h-5 w-5 text-[var(--color-muted)]"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          ><title>Meta</title><path
            d="M6.915 4.03c-1.968 0-3.683 1.28-4.871 3.113C.704 9.208 0 11.883 0 14.449c0 .706.07 1.369.21 1.973a6.624 6.624 0 0 0 .265.86 5.297 5.297 0 0 0 .371.761c.696 1.159 1.818 1.927 3.593 1.927 1.497 0 2.633-.671 3.965-2.444.76-1.012 1.144-1.626 2.663-4.32l.756-1.339.186-.325c.061.1.121.196.183.3l2.152 3.595c.724 1.21 1.665 2.556 2.47 3.314 1.046.987 1.992 1.22 3.06 1.22 1.075 0 1.876-.355 2.455-.843a3.743 3.743 0 0 0 .81-.973c.542-.939.861-2.127.861-3.745 0-2.72-.681-5.357-2.084-7.45-1.282-1.912-2.957-2.93-4.716-2.93-1.047 0-2.088.467-3.053 1.308-.652.57-1.257 1.29-1.82 2.05-.69-.875-1.335-1.547-1.958-2.056-1.182-.966-2.315-1.303-3.454-1.303zm10.16 2.053c1.147 0 2.188.758 2.992 1.999 1.132 1.748 1.647 4.195 1.647 6.4 0 1.548-.368 2.9-1.839 2.9-.58 0-1.027-.23-1.664-1.004-.496-.601-1.343-1.878-2.832-4.358l-.617-1.028a44.908 44.908 0 0 0-1.255-1.98c.07-.109.141-.224.211-.327 1.12-1.667 2.118-2.602 3.358-2.602zm-10.201.553c1.265 0 2.058.791 2.675 1.446.307.327.737.871 1.234 1.579l-1.02 1.566c-.757 1.163-1.882 3.017-2.837 4.338-1.191 1.649-1.81 1.817-2.486 1.817-.524 0-1.038-.237-1.383-.794-.263-.426-.464-1.13-.464-2.046 0-2.221.63-4.535 1.66-6.088.454-.687.964-1.226 1.533-1.533a2.264 2.264 0 0 1 1.088-.285z"
          ></path></svg
        >
        <span>Meta</span>
      </span>
    </div>
  </section>

  <!-- What I do -->
  <section class="py-20">
    <p class="eyebrow">{t.home.whatIDoEyebrow}</p>
    <h2 class="mt-4 text-3xl sm:text-4xl">{t.home.whatIDoTitle}</h2>
    <p class="mt-4 max-w-2xl text-lg text-[var(--color-fg-soft)]">
      {t.home.whatIDoLead}
    </p>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      <div class="card">
        <p
          class="text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]"
        >
          {t.home.forStudents}
        </p>
        <h3 class="mt-3 text-2xl">{t.home.forStudentsTitle}</h3>
        <p class="mt-3 text-[var(--color-fg-soft)]">{t.home.forStudentsBody}</p>
        <a
          href={localizedPath(lang, "/about")}
          class="mt-5 inline-block text-sm font-medium"
          >{t.home.forStudentsLink}</a
        >
      </div>
      <div class="card">
        <p
          class="text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]"
        >
          {t.home.forCompanies}
        </p>
        <h3 class="mt-3 text-2xl">{t.home.forCompaniesTitle}</h3>
        <p class="mt-3 text-[var(--color-fg-soft)]">
          {t.home.forCompaniesBody}
        </p>
        <a
          href={localizedPath(lang, "/consulting")}
          class="mt-5 inline-block text-sm font-medium"
          >{t.home.forCompaniesLink}</a
        >
      </div>
    </div>
  </section>

  <!-- Pillar articles -->
  {
    pillarPosts.length > 0 && (
      <section class="border-t border-[var(--color-border)] py-20">
        <p class="eyebrow">{t.home.pillarsEyebrow}</p>
        <h2 class="mt-4 text-3xl sm:text-4xl">{t.home.pillarsTitle}</h2>
        <p class="mt-4 max-w-2xl text-lg text-[var(--color-fg-soft)]">
          {t.home.pillarsLead}
        </p>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {pillarPosts.map((post) => (
            <a
              href={localizedPath(lang, `/blog/${post.data.slug ?? post.id}`)}
              class="card group flex flex-col no-underline"
            >
              <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
                {t.home.pillarsEyebrow}
              </p>
              <h3 class="mt-3 text-xl text-[var(--color-fg)] transition group-hover:text-[var(--color-accent)]">
                {post.data.title}
              </h3>
              <p class="mt-3 flex-1 text-[var(--color-fg-soft)]">
                {post.data.description}
              </p>
              <span class="mt-5 text-sm font-medium text-[var(--color-accent)]">
                {t.home.pillarsRead}
              </span>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <!-- Latest writing -->
  {
    latestPosts.length > 0 && (
      <section class="border-t border-[var(--color-border)] py-20">
        <div class="flex items-baseline justify-between">
          <div>
            <p class="eyebrow">{t.home.writingEyebrow}</p>
            <h2 class="mt-4 text-3xl sm:text-4xl">{t.home.writingTitle}</h2>
          </div>
          <a
            href={localizedPath(lang, "/blog")}
            class="text-sm font-medium no-underline"
          >
            {t.home.writingAll}
          </a>
        </div>
        <ul class="mt-12 divide-y divide-[var(--color-border)]">
          {latestPosts.map((post) => (
            <li>
              <a
                href={localizedPath(lang, `/blog/${post.data.slug ?? post.id}`)}
                class="group grid gap-2 py-6 no-underline sm:grid-cols-[8rem_1fr] sm:gap-8"
              >
                <p class="text-sm text-[var(--color-muted)]">
                  {post.data.pubDate.toLocaleDateString(dateLocale, {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </p>
                <div>
                  <h3 class="text-xl text-[var(--color-fg)] transition group-hover:text-[var(--color-accent)]">
                    {post.data.title}
                  </h3>
                  <p class="mt-1 text-[var(--color-fg-soft)]">
                    {post.data.description}
                  </p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <!-- CTA -->
  <section class="border-t border-[var(--color-border)] py-20">
    <div class="card text-center sm:p-12">
      <p class="eyebrow justify-center" style="display:inline-flex;">
        {t.home.ctaEyebrow}
      </p>
      <h2 class="mt-4 text-3xl sm:text-4xl">{t.home.ctaTitle}</h2>
      <p class="mx-auto mt-4 max-w-xl text-[var(--color-fg-soft)]">
        {t.home.ctaBody}
      </p>
      <div class="mt-8">
        <a href={localizedPath(lang, "/contact")} class="btn-primary">
          {t.home.ctaButton}
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
