---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import aiwhiteboard from "../../assets/aiwhiteboard.jpg";
import { useTranslations, localizedPath } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<Layout lang={lang} title={t.consulting.title} description={t.consulting.lead}>
  <!-- Hero -->
  <section class="grid items-center gap-12 py-16 md:grid-cols-[1.3fr_1fr]">
    <div>
      <p class="eyebrow">{t.consulting.eyebrow}</p>
      <h1 class="mt-6 text-5xl sm:text-6xl">
        {t.consulting.headlinePre}{" "}
        <span class="italic text-[var(--color-accent)]"
          >{t.consulting.headlineAccent}</span
        >{t.consulting.headlinePost}
      </h1>
      <p class="mt-8 max-w-xl text-lg text-[var(--color-fg-soft)]">
        {t.consulting.lead}
      </p>
      <div class="mt-10">
        <a href={localizedPath(lang, "/contact")} class="btn-primary">
          {t.consulting.ctaTop}
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
    <Image
      src={aiwhiteboard}
      alt={t.consulting.heroImageLabel}
      widths={[400, 600, 900]}
      sizes="(min-width: 768px) 400px, 100vw"
      format="webp"
      class="rounded-xl"
    />
  </section>

  <!-- Services -->
  <section class="border-t border-[var(--color-border)] py-16">
    <p class="eyebrow">{t.consulting.servicesEyebrow}</p>
    <h2 class="mt-4 text-3xl sm:text-4xl">{t.consulting.servicesTitle}</h2>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {
        t.consulting.services.map((s) =>
          s.href ? (
            <a href={s.href} class="card group block no-underline">
              <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
                {s.n}
              </p>
              <h3 class="mt-3 text-2xl text-[var(--color-fg)] transition group-hover:text-[var(--color-accent)]">
                {s.title}
              </h3>
              <p class="mt-3 text-[var(--color-fg-soft)]">{s.body}</p>
              <p class="mt-4 text-sm font-medium text-[var(--color-accent)]">
                {lang === "de" ? "Mehr erfahren →" : "Learn more →"}
              </p>
            </a>
          ) : (
            <div class="card">
              <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">
                {s.n}
              </p>
              <h3 class="mt-3 text-2xl">{s.title}</h3>
              <p class="mt-3 text-[var(--color-fg-soft)]">{s.body}</p>
            </div>
          ),
        )
      }
    </div>
  </section>

  <!-- Why me -->
  <section class="border-t border-[var(--color-border)] py-16">
    <div class="grid gap-12 md:grid-cols-[1fr_1.2fr]">
      <div>
        <p class="eyebrow">{t.consulting.whyEyebrow}</p>
        <h2 class="mt-4 text-3xl sm:text-4xl">{t.consulting.whyTitle}</h2>
      </div>
      <div class="prose-content">
        <p>{t.consulting.whyP1}</p>
        <p>{t.consulting.whyP2}</p>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="border-t border-[var(--color-border)] py-16">
    <p class="eyebrow">{t.consulting.testimonialsEyebrow}</p>
    <h2 class="mt-4 text-3xl sm:text-4xl">{t.consulting.testimonialsTitle}</h2>
    
    <div class="scrollbar-hide mt-12 flex snap-x snap-mandatory gap-6 overflow-x-auto pb-8" style="scrollbar-width: none; -ms-overflow-style: none;">
      <style>
        .scrollbar-hide::-webkit-scrollbar {
          display: none;
        }
      </style>
      {t.consulting.testimonials.map((testi) => (
        <div class="card w-[85vw] shrink-0 snap-center whitespace-normal sm:w-[400px] md:w-[500px]">
          <p class="text-lg italic text-[var(--color-fg-soft)]">"{testi.quote}"</p>
          <div class="mt-8 flex items-center gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-[var(--color-border)] font-bold text-[var(--color-fg-soft)]">
              {testi.name.charAt(0)}
            </div>
            <div>
              <p class="font-bold text-[var(--color-fg)]">{testi.name}</p>
              <p class="text-sm text-[var(--color-muted)]">{testi.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-[var(--color-border)] py-16">
    <div class="card sm:p-12">
      <p class="eyebrow">{t.consulting.ctaEyebrow}</p>
      <h2 class="mt-4 text-3xl sm:text-4xl">{t.consulting.ctaTitle}</h2>
      <p class="mt-4 max-w-2xl text-[var(--color-fg-soft)]">
        {t.consulting.ctaBody}
      </p>
      <a href={localizedPath(lang, "/contact")} class="btn-primary mt-8">
        {t.consulting.ctaButton}
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</Layout>
