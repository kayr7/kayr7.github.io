---
import Layout from "../../layouts/Layout.astro";
import { useTranslations, localizedPath } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";
import { getCollection } from "astro:content";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const allPosts = (
  await getCollection(
    "blog",
    ({ data }) => !data.draft && (data.lang ?? "de") === lang,
  )
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pillarPosts = allPosts.filter((p) => p.data.tags?.includes("pillar"));
const pillarIds = new Set(pillarPosts.map((p) => p.id));
const otherPosts = allPosts.filter((p) => !pillarIds.has(p.id));

const dateLocale = lang === "de" ? "de-DE" : "en-US";
---

<Layout lang={lang} title={t.blog.title}>
  <section class="py-16">
    <p class="eyebrow">{t.blog.eyebrow}</p>
    <h1 class="mt-6 text-5xl sm:text-6xl">{t.blog.headline}</h1>
    <p class="mt-8 max-w-2xl text-lg text-[var(--color-fg-soft)]">
      {t.blog.lead}
    </p>
  </section>

  {
    pillarPosts.length > 0 && (
      <section class="border-t border-[var(--color-border)] py-12">
        <h2 class="text-2xl uppercase tracking-wider text-[var(--color-muted)] sm:text-sm">
          {t.blog.pillarsTitle}
        </h2>
        <p class="mt-3 max-w-2xl text-[var(--color-fg-soft)]">
          {t.blog.pillarsLead}
        </p>
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {pillarPosts.map((post) => (
            <a
              href={localizedPath(lang, `/blog/${post.data.slug ?? post.id}`)}
              class="card group flex flex-col no-underline"
            >
              <h3 class="text-xl text-[var(--color-fg)] transition group-hover:text-[var(--color-accent)]">
                {post.data.title}
              </h3>
              <p class="mt-3 flex-1 text-[var(--color-fg-soft)]">
                {post.data.description}
              </p>
            </a>
          ))}
        </div>
      </section>
    )
  }

  {
    otherPosts.length > 0 && (
      <section class="border-t border-[var(--color-border)] pt-12">
        <h2 class="text-sm uppercase tracking-wider text-[var(--color-muted)]">
          {t.blog.latestTitle}
        </h2>
        <ul class="mt-4 divide-y divide-[var(--color-border)]">
          {otherPosts.map((post) => (
            <li>
              <a
                href={localizedPath(lang, `/blog/${post.data.slug ?? post.id}`)}
                class="group grid gap-2 py-8 no-underline sm:grid-cols-[10rem_1fr] sm:gap-8"
              >
                <p class="text-sm text-[var(--color-muted)]">
                  {post.data.pubDate.toLocaleDateString(dateLocale, {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </p>
                <div>
                  <h2 class="text-2xl text-[var(--color-fg)] transition group-hover:text-[var(--color-accent)]">
                    {post.data.title}
                  </h2>
                  <p class="mt-2 text-[var(--color-fg-soft)]">
                    {post.data.description}
                  </p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Layout>
